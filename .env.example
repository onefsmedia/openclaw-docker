# OpenClaw Docker — Environment Variables
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Domain (VPS deployment) ───────────────────────────────────────────────────
# Your subdomain pointing to this VPS (e.g. app.yourdomain.com).
# Caddy uses this to automatically obtain a Let's Encrypt TLS certificate.
# Make sure your DNS A record points to this server's IP before starting.
DOMAIN=app.yourdomain.com

# ── OpenClaw ──────────────────────────────────────────────────────────────────
# Path to your ~/.openclaw directory on the host.
# The container mounts this directory as /data (read+write).
OPENCLAW_DATA_DIR=~/.openclaw

# Gateway auth token — must match the value in openclaw.json
# (gateway.auth.token). Leave blank to use whatever is in the config file.
OPENCLAW_GATEWAY_TOKEN=

# Gateway port exposed on the host (bound to 127.0.0.1 only)
OPENCLAW_GATEWAY_PORT=9090

# ── Google Sheets ─────────────────────────────────────────────────────────────
# ID from the Sheet URL: /spreadsheets/d/<GOOGLE_SHEET_ID>/edit
GOOGLE_SHEET_ID=

# Tab name in the spreadsheet (default: WhatsApp Data)
GOOGLE_SHEET_TAB=WhatsApp Data

# Default Gmail account used by gog (avoids --account flag every time)
GOG_ACCOUNT=

# ── ClickUp ───────────────────────────────────────────────────────────────────
# Personal API token from: https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=

# List ID from the ClickUp list URL: /l/<LIST_ID>/
CLICKUP_LIST_ID=

# ── OpenClaw Studio ───────────────────────────────────────────────────────────
# Path to your local openclaw-studio source directory (used as Docker build context)
OPENCLAW_STUDIO_DIR=~/openclaw-studio

# Access token for Studio — required when HOST=0.0.0.0 (all Docker deployments).
# Generate with: openssl rand -hex 24
STUDIO_ACCESS_TOKEN=change_me_before_exposing_to_network
