# OpenClaw Docker — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Replace every <placeholder> with the real value.
# 3. Never commit .env — it is already in .gitignore.

# ── Domain ────────────────────────────────────────────────────────────────────
# Your VPS subdomain. Create a DNS A record pointing to your server's IP first.
DOMAIN=<your-subdomain.yourdomain.com>

# ── OpenClaw Gateway ──────────────────────────────────────────────────────────
# Auth token used to authenticate the Control UI and paired devices.
# Generate with: openssl rand -hex 24
OPENCLAW_GATEWAY_TOKEN=<generate-with-openssl-rand-hex-24>

# Gateway port (internal; nginx proxies to this)
OPENCLAW_GATEWAY_PORT=9090

# ── OpenRouter API ────────────────────────────────────────────────────────────
# API key from https://openrouter.ai/keys
# Used in config/agents/main/agent/auth-profiles.json (see auth-profiles.json.example)
OPENROUTER_API_KEY=<sk-or-v1-your-key>

# ── Google Sheets ─────────────────────────────────────────────────────────────
# ID from the Sheet URL: /spreadsheets/d/<GOOGLE_SHEET_ID>/edit
GOOGLE_SHEET_ID=<your-google-sheet-id>

# Tab name in the spreadsheet.
GOOGLE_SHEET_TAB=WhatsApp Data

# Gmail account used by the gog CLI.
GOG_ACCOUNT=<your-gmail@gmail.com>

# ── ClickUp ───────────────────────────────────────────────────────────────────
# Personal API token from: https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=<pk_your_clickup_api_token>

# List ID from the ClickUp list URL: /l/<LIST_ID>/
CLICKUP_LIST_ID=<your-clickup-list-id>
